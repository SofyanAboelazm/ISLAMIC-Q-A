rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: searchHistory
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - query: string (required)
    //   - answer: string (required)
    //   - timestamp: timestamp (required)
    //   - references: list (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 100;
    }

    function isValidSearchHistory(data) {
      return data.keys().hasAll(['userId', 'query', 'answer', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.query is string && data.query.size() < 1000 &&
             data.answer is string && data.answer.size() < 10000;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /searchHistory/{historyId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSearchHistory(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
