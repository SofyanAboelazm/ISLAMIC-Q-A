{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SearchHistory": {
      "title": "Search History",
      "description": "User's search history for religious questions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "answer": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": { "type": "string" },
              "book": { "type": "string" },
              "reference": { "type": "string" }
            }
          }
        }
      },
      "required": ["userId", "query", "answer", "timestamp"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A chat session between a user and the AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "userId", "timestamp"]
    },
    "VoiceChatSession": {
      "title": "Voice Chat Session",
      "description": "A voice chat session between a user and the AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "voiceType": { "type": "string", "enum": ["male", "female"] },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "voiceType", "title", "createdAt", "updatedAt"]
    },
    "VoiceChatMessage": {
      "title": "Voice Chat Message",
      "description": "A message in a voice chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/searchHistory/{historyId}": {
      "schema": "SearchHistory",
      "description": "Search history records"
    },
    "/chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat session documents"
    },
    "/chatSessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a chat session"
    },
    "/voiceChatSessions/{sessionId}": {
      "schema": "VoiceChatSession",
      "description": "Voice chat session documents"
    },
    "/voiceChatSessions/{sessionId}/messages/{messageId}": {
      "schema": "VoiceChatMessage",
      "description": "Messages within a voice chat session"
    }
  }
}
